# Supabase (required)
# Create a project at https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — use in API routes / sync workers. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Secret guarding the cron sync route. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
# Set the same value in Vercel project env so Vercel Cron can authenticate.
CRON_SECRET=your-cron-secret

# Optional: mock platform failure mode for local testing
# Values: rate_limit | page2 | auth | timeout (see MOCK_DATA.md)
# MOCK_PLATFORM_FAIL=

# Optional: site URL for Supabase Auth redirects (local dev)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
